# SoloLab - 反向代理配置（生产）

{$SOLOLAB_DOMAIN:localhost} {
	# 健康检查
	handle /health {
		reverse_proxy backend:8000
	}

	# 后端 API
	handle /api/* {
		reverse_proxy backend:8000
	}

	# OpenCode 直连（CodeLab 模块）
	handle_path /oc/* {
		reverse_proxy opencode:3100 {
			flush_interval -1
		}
	}

	# 前端
	handle {
		reverse_proxy frontend:3000
	}

	# 日志
	log {
		output stdout
		format json
	}
}
