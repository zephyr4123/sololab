{
  "$schema": "https://opencode.ai/config.json",
  // SoloLab CodeLab 模块 — OpenCode 引擎配置
  // 环境变量通过 {env:XXX} 语法从 SoloLab .env 读取
  // MOONSHOT_API_KEY 会被 moonshotai-cn provider 自动识别

  "server": {
    "port": 3100,
    "hostname": "127.0.0.1"
  },

  // 默认模型（格式: providerID/modelID）
  // moonshotai-cn 是 OpenCode 内置 provider，自动从 MOONSHOT_API_KEY 读取密钥
  // 可用模型: kimi-k2.5, kimi-k2-thinking, kimi-k2-thinking-turbo 等
  "model": "moonshotai-cn/kimi-k2.5",

  // 权限配置：保护关键文件
  "permission": {
    "edit": {
      "packages/opencode/migration/*": "deny"
    }
  },

  // 禁用不需要的工具
  "tools": {
    "github-triage": false,
    "github-pr-search": false
  }
}
