{
  "$schema": "https://opencode.ai/config.json",
  // SoloLab CodeLab 模块 — OpenCode 引擎配置
  //
  // 用户只需在 .env 中设置三个变量即可：
  //   CODELAB_API_KEY  — API 密钥
  //   CODELAB_MODEL    — 模型（格式: providerID/modelID）
  //   CODELAB_BASE_URL — LLM API 端点（anthropic/openai/google 原生 SDK 可不设）
  //
  // 切换 Provider 示例：
  //   Qwen:       CODELAB_MODEL=alibaba-cn/qwen3.5-plus         CODELAB_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
  //   Moonshot:   CODELAB_MODEL=moonshotai-cn/kimi-k2.5         CODELAB_BASE_URL=https://api.moonshot.cn/v1
  //   DeepSeek:   CODELAB_MODEL=deepseek/deepseek-chat          CODELAB_BASE_URL=https://api.deepseek.com/v1
  //   Anthropic:  CODELAB_MODEL=anthropic/claude-sonnet-4-5      （无需 BASE_URL）
  //   OpenAI:     CODELAB_MODEL=openai/gpt-4o                   （无需 BASE_URL）
  //   Google:     CODELAB_MODEL=google/gemini-2.5-flash          （无需 BASE_URL）

  "server": {
    "port": 3100,
    "hostname": "127.0.0.1"
  },

  // 默认模型（从 .env 的 CODELAB_MODEL 读取）
  "model": "{env:CODELAB_MODEL}",

  // 权限配置：保护关键文件
  "permission": {
    "edit": {
      "packages/opencode/migration/*": "deny"
    }
  },

  // 禁用不需要的工具
  "tools": {
    "github-triage": false,
    "github-pr-search": false
  }
}
