# ============================================
# SoloLab 环境变量
# 复制此文件为 .env 并填入你的配置
# ============================================

# --- 应用 ---
DEBUG=false

# --- PostgreSQL ---
POSTGRES_USER=sololab
POSTGRES_PASSWORD=sololab
POSTGRES_DB=sololab
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PASSWORD=sololab
REDIS_PORT=6379

# --- 数据库连接（本地开发用 localhost，Docker 内部自动覆盖为服务名）---
DATABASE_URL=postgresql+asyncpg://sololab:sololab@localhost:5432/sololab
REDIS_URL=redis://:sololab@localhost:6379/0

# ══════════════════════════════════════════════
# IdeaSpark 模块（后端 LLM Gateway，OpenAI 兼容格式）
# 支持: OpenAI / Google / DeepSeek / OpenRouter 等任意兼容 API
# ══════════════════════════════════════════════
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-xxx
LLM_MODEL=gpt-4o
BUDGET_LIMIT_USD=50.0

# ══════════════════════════════════════════════
# CodeLab 模块（OpenCode 引擎，Vercel AI SDK 直连）
# 模型在 opencode/opencode.jsonc 中配置，密钥从此处读取
# 支持的 Provider: moonshot / google / anthropic / openai / openrouter 等 15+
# ══════════════════════════════════════════════
# Moonshot（Kimi）
MOONSHOT_API_KEY=sk-xxx
# Google Gemini（备选）
# GOOGLE_API_KEY=your-google-api-key
# GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# OpenCode Server 连接
OPENCODE_PORT=3100
OPENCODE_HOST=127.0.0.1
OPENCODE_SERVER_PASSWORD=
OPENCODE_SERVER_USERNAME=opencode
OPENCODE_URL=http://localhost:3100

# ══════════════════════════════════════════════
# 向量嵌入（OpenAI 兼容格式，独立于 LLM 提供商）
# ══════════════════════════════════════════════
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=sk-xxx
EMBEDDING_MODEL=text-embedding-3-small

# ══════════════════════════════════════════════
# 评测（Benchmark Judge，独立于主 LLM）
# ══════════════════════════════════════════════
# JUDGE_BASE_URL=https://api.openai.com/v1
# JUDGE_API_KEY=sk-xxx
# JUDGE_MODEL=gpt-4o

# ══════════════════════════════════════════════
# 外部 API
# ══════════════════════════════════════════════
TAVILY_API_KEY=tvly-xxx
S2_API_KEY=  # Semantic Scholar API Key

# --- API 认证（逗号分隔多个 key，留空禁用认证）---
# API_KEYS=sk-sololab-xxx,sk-sololab-yyy

# --- 存储 ---
STORAGE_PATH=./storage

# --- 地址 ---
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
