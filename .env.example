# ============================================
# SoloLab 环境变量（Docker 部署）
# 复制此文件为 .env 并填入你的配置
#
# ⚠️ API key 占位符（sk-xxx 等）会被 LLMConfig 在启动时拒绝。
#    请填入真实 key，否则后端启动会报 ValidationError。
# ============================================

DEBUG=false

# --- 基础设施密码 ---
POSTGRES_PASSWORD=sololab
REDIS_PASSWORD=sololab

# ══════════════════════════════════════════════
# IdeaSpark 模块（必填，OpenAI 兼容格式）
# 支持: OpenAI / Google / DeepSeek / Qwen / OpenRouter 等任意兼容 API
# ══════════════════════════════════════════════
IDEASPARK_BASE_URL=https://api.openai.com/v1
IDEASPARK_API_KEY=                            # 必填，留空启动会失败
IDEASPARK_MODEL=gpt-4o

# 任务级预算（USD）；LLM 调用前会真正 enforce — 超出抛 BudgetExceededError
BUDGET_LIMIT_USD=50.0

# ══════════════════════════════════════════════
# CodeLab 模块（AI 编码助手 — 由 OpenCode 容器直接读取）
# ══════════════════════════════════════════════
# 只需 3 个变量即可切换任意 LLM：
#   CODELAB_API_KEY   — API 密钥
#   CODELAB_MODEL     — providerID/modelID
#   CODELAB_BASE_URL  — API 端点（见下方规则）
#
# ── BASE_URL 规则 ──
#   anthropic / openai / google → 无需设 BASE_URL（自动使用官方端点）
#   其他所有 provider            → 必须设 BASE_URL（OpenAI 兼容端点）
#
# ── 配置示例 ──
#   Anthropic:  MODEL=anthropic/claude-sonnet-4-5                                   （无需 BASE_URL）
#   OpenAI:     MODEL=openai/gpt-4o                                                 （无需 BASE_URL）
#   Google:     MODEL=google/gemini-2.5-flash                                        （无需 BASE_URL）
#   Qwen:       MODEL=alibaba-cn/qwen3.5-plus     BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   Moonshot:   MODEL=moonshotai-cn/kimi-k2.5      BASE_URL=https://api.moonshot.cn/v1
#   DeepSeek:   MODEL=deepseek/deepseek-chat       BASE_URL=https://api.deepseek.com/v1
#   GLM:        MODEL=zhipuai/glm-4.7              BASE_URL=https://open.bigmodel.cn/api/paas/v4
#   OpenRouter: MODEL=openrouter/anthropic/claude-sonnet-4-5   BASE_URL=https://openrouter.ai/api/v1
#
CODELAB_BASE_URL=https://api.moonshot.cn/v1
CODELAB_API_KEY=
CODELAB_MODEL=moonshotai-cn/kimi-k2.5

# OpenCode HTTP 服务密码（留空 = 公开访问，仅适合本地部署）
OPENCODE_SERVER_PASSWORD=

# ══════════════════════════════════════════════
# WriterAI 模块（学术论文写作）
# 留空则复用 IDEASPARK_* 配置（推荐）
# ══════════════════════════════════════════════
# WRITER_BASE_URL=
# WRITER_API_KEY=
# WRITER_MODEL=
WRITER_SANDBOX_TIMEOUT=30
WRITER_SANDBOX_MEMORY=512m

# ══════════════════════════════════════════════
# 向量嵌入（必填，OpenAI 兼容格式，可独立于主 LLM 提供商）
# ══════════════════════════════════════════════
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=                            # 必填，留空启动会失败
EMBEDDING_MODEL=text-embedding-3-small

# 嵌入维度 — 默认 1024（匹配阿里 text-embedding-v4）
# 换模型时同步调，且需要重建 memories / document_chunks 表
EMBEDDING_DIM=1024

# ══════════════════════════════════════════════
# 外部 API
# ══════════════════════════════════════════════
TAVILY_API_KEY=                               # Tavily 搜索；留空则该工具返回错误
S2_API_KEY=                                   # Semantic Scholar 可选（提高限速）

# ══════════════════════════════════════════════
# API 认证
# 留空 = 所有路由放行（dev 默认）
# 设置 = 所有 mutation 路由要求 X-API-Key header
# 生成 key: APIKeyAuth.generate_key() 返回 sk-sololab-<token>
# ══════════════════════════════════════════════
# API_KEYS=sk-sololab-xxx,sk-sololab-yyy

# ══════════════════════════════════════════════
# 可观测
# ══════════════════════════════════════════════
LOG_LEVEL=INFO                                # DEBUG / INFO / WARNING / ERROR
LOG_JSON=false                                # 生产建议 true，方便 ELK / Loki 聚合

# CORS 允许的 Origin（逗号分隔）
# 使用 "*" 时 allow_credentials 会自动关闭（浏览器拒绝 *+credentials 组合）
CORS_ALLOW_ORIGINS=http://localhost:3000

# ══════════════════════════════════════════════
# 工作区与存储
# ══════════════════════════════════════════════
# CodeLab Agent 的沙箱边界 — Agent 只能读写此目录下的文件
# 示例: /home/user/projects 或 /Users/xxx/coding
WORKSPACE_DIR=/path/to/your/code

# 沙箱生成的图表等运行时文件目录
STORAGE_PATH=./storage
