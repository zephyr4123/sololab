# ============================================
# SoloLab 环境变量
# 复制此文件为 .env 并填入你的配置
# ============================================

# --- 应用 ---
DEBUG=false

# --- PostgreSQL ---
POSTGRES_USER=sololab
POSTGRES_PASSWORD=sololab
POSTGRES_DB=sololab
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PASSWORD=sololab
REDIS_PORT=6379

# --- 数据库连接（本地开发用 localhost，Docker 内部自动覆盖为服务名）---
DATABASE_URL=postgresql+asyncpg://sololab:sololab@localhost:5432/sololab
REDIS_URL=redis://:sololab@localhost:6379/0

# --- LLM 配置（SoloLab 后端使用，OpenAI 兼容格式）---
# 支持任意 OpenAI 兼容的 API 代理（OpenAI / Google / DeepSeek / one-api / new-api 等）
# 示例：
#   OpenAI 官方:  LLM_BASE_URL=https://api.openai.com/v1         LLM_MODEL=gpt-4o
#   Google 代理:  LLM_BASE_URL=https://your-proxy.com/v1beta     LLM_MODEL=gemini-3-flash-preview
#   DeepSeek:     LLM_BASE_URL=https://api.deepseek.com/v1       LLM_MODEL=deepseek-chat
#   OpenRouter:   LLM_BASE_URL=https://openrouter.ai/api/v1      LLM_MODEL=google/gemini-3-flash-preview
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-xxx
LLM_MODEL=gpt-4o
BUDGET_LIMIT_USD=50.0

# --- Embedding 配置（OpenAI 兼容格式，可使用不同提供商）---
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=sk-xxx
EMBEDDING_MODEL=text-embedding-3-small

# --- Judge LLM 配置（Benchmark 评测专用，可独立于主 LLM）---
# JUDGE_BASE_URL=https://api.openai.com/v1
# JUDGE_API_KEY=sk-xxx
# JUDGE_MODEL=gpt-4o

# --- 外部 API ---
TAVILY_API_KEY=tvly-xxx
S2_API_KEY=  # Semantic Scholar API Key（申请地址：https://www.semanticscholar.org/product/api）

# --- API 认证（逗号分隔多个 key，留空禁用认证）---
# API_KEYS=sk-sololab-xxx,sk-sololab-yyy

# --- 存储 ---
STORAGE_PATH=./storage

# --- 地址 ---
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# --- OpenCode 引擎（CodeLab 模块）---
# OpenCode Server 端口（SoloLab 后端通过此端口桥接）
OPENCODE_PORT=3100
OPENCODE_HOST=127.0.0.1
# OpenCode Server 认证（生产环境必须设置）
OPENCODE_SERVER_PASSWORD=
OPENCODE_SERVER_USERNAME=opencode
# OpenCode 内部 URL（Docker 内部使用服务名，本地开发用 localhost）
OPENCODE_URL=http://localhost:3100

# --- OpenCode LLM Provider（Vercel AI SDK 直连）---
# OpenCode 通过 @ai-sdk/google 直连 Google Gemini API
# 如使用其他 Provider，在 opencode/opencode.jsonc 中配置 provider 字段
# 支持的 Provider: google / anthropic / openai / openrouter / bedrock 等 15+
GOOGLE_API_KEY=your-google-api-key
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta
