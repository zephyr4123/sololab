# ============================================
# SoloLab 环境变量（Docker 部署）
# 复制此文件为 .env 并填入你的配置
# ============================================

DEBUG=false

# --- 基础设施密码 ---
POSTGRES_PASSWORD=sololab
REDIS_PASSWORD=sololab

# ══════════════════════════════════════════════
# IdeaSpark 模块（多智能体创意生成，OpenAI 兼容格式）
# 支持: OpenAI / Google / DeepSeek / OpenRouter 等任意兼容 API
# ══════════════════════════════════════════════
IDEASPARK_BASE_URL=https://api.openai.com/v1
IDEASPARK_API_KEY=sk-xxx
IDEASPARK_MODEL=gpt-4o
BUDGET_LIMIT_USD=50.0

# ══════════════════════════════════════════════
# CodeLab 模块（AI 编码助手）
# ══════════════════════════════════════════════
# CODELAB_MODEL 格式: providerID/modelID
# 切换 Provider 只需修改下面三个变量，无需改其他配置文件。
#
# 配置示例:
#   Moonshot  → BASE_URL=https://api.moonshot.cn/v1  MODEL=moonshotai-cn/kimi-k2.5
#   Anthropic → （BASE_URL 留空即可）                  MODEL=anthropic/claude-sonnet-4-5
#   OpenAI    → （BASE_URL 留空即可）                  MODEL=openai/gpt-4o
#   DeepSeek  → （BASE_URL 留空即可）                  MODEL=deepseek/deepseek-chat
#   Qwen      → （BASE_URL 留空即可）                  MODEL=alibaba-cn/qwen3-coder-30b-a3b
#   Gemini    → （BASE_URL 留空即可）                  MODEL=google/gemini-2.5-flash
#   GLM       → （BASE_URL 留空即可）                  MODEL=zhipuai/glm-4.7
#
# CODELAB_BASE_URL 仅在需要覆盖默认 API 端点时设置（如使用代理）。
# 大多数 provider 有内置端点，留空会自动使用官方地址。
#
# ┌─────────────── 完整 Provider 前缀参考 ───────────────┐
# │                                                       │
# │ ── 模型厂商（直连官方 API）──                          │
# │  anthropic        Anthropic (Claude)                  │
# │  openai           OpenAI (GPT/o-series)               │
# │  google           Google (Gemini)                     │
# │  deepseek         DeepSeek                            │
# │  xai              xAI (Grok)                          │
# │  mistral          Mistral                             │
# │  cohere           Cohere (Command)                    │
# │  minimax          MiniMax                             │
# │  minimax-cn       MiniMax 国内                        │
# │  moonshotai-cn    Moonshot 国内 (Kimi)                │
# │  moonshotai       Moonshot 国际                       │
# │  perplexity       Perplexity (Sonar)                  │
# │                                                       │
# │ ── 国内模型厂商 ──                                     │
# │  alibaba-cn       阿里通义（DashScope 国内）           │
# │  alibaba          阿里通义（DashScope 国际）           │
# │  zhipuai          智谱 AI (GLM)                       │
# │  siliconflow-cn   硅基流动（国内）                     │
# │  modelscope       魔搭社区                            │
# │  xiaomi           小米 (MiMo)                         │
# │                                                       │
# │ ── 推理平台（聚合多模型）──                            │
# │  openrouter       OpenRouter (149 模型)               │
# │  groq             Groq (极速推理)                     │
# │  fireworks-ai     Fireworks AI                        │
# │  togetherai       Together AI                         │
# │  deepinfra        Deep Infra                          │
# │  cerebras         Cerebras                            │
# │  siliconflow      SiliconFlow（国际）                  │
# │  nvidia           Nvidia NIM                          │
# │  novita-ai        Novita AI                           │
# │  huggingface      Hugging Face                        │
# │                                                       │
# │ ── 其他（需要自行在 opencode.jsonc 添加配置）──        │
# │  amazon-bedrock   AWS Bedrock（需 AWS 凭证）          │
# │  azure            Azure OpenAI（需资源名）            │
# │  google-vertex    Google Vertex AI（需项目 ID）       │
# │  github-copilot   GitHub Copilot                      │
# │  github-models    GitHub Models                       │
# │  ollama-cloud     Ollama Cloud                        │
# │  302ai / aihubmix / poe / venice / ...               │
# │                                                       │
# │ 完整列表: https://models.dev                          │
# └───────────────────────────────────────────────────────┘
#
CODELAB_BASE_URL=https://api.moonshot.cn/v1
CODELAB_API_KEY=sk-xxx
CODELAB_MODEL=moonshotai-cn/kimi-k2.5
OPENCODE_SERVER_PASSWORD=

# ══════════════════════════════════════════════
# 向量嵌入（OpenAI 兼容格式，独立于 LLM 提供商）
# ══════════════════════════════════════════════
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=sk-xxx
EMBEDDING_MODEL=text-embedding-3-small

# ══════════════════════════════════════════════
# 外部 API
# ══════════════════════════════════════════════
TAVILY_API_KEY=tvly-xxx
S2_API_KEY=

# --- API 认证（逗号分隔多个 key，留空禁用认证）---
# API_KEYS=sk-sololab-xxx,sk-sololab-yyy

# --- 工作区（CodeLab 沙箱边界）---
# Agent 只能读写此目录下的文件，其余系统文件不可见
# 示例: /home/user/projects 或 /Users/xxx/coding
WORKSPACE_DIR=/path/to/your/code

# --- 存储 ---
STORAGE_PATH=./storage

# --- 评测（可选，Benchmark Judge 独立于主 LLM）---
# JUDGE_BASE_URL=https://api.openai.com/v1
# JUDGE_API_KEY=sk-xxx
# JUDGE_MODEL=gpt-4o
